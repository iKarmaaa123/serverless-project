env = "dev"
api_gateway_name = "username-api"
path_part = "create-user"
http_method = "POST"
authorization = "NONE"
integration_input_type = "AWS_PROXY"
stage_name = "dev"
dynamodb_table_name = "users-table"
hash_key = "users"
billing_mode = "PAY_PER_REQUEST"
stream_enabled = true
attribute_name = "users"
attribute_key_type = "S"
dynamodb_lambda_function_name = "lambda-function-dynamodb"
s3_lambda_function_name = "lambda-function-s3"
lambda_execution_role_name = "lambda-function-dynanodb-role"
method_type = "zip"
dynamodb_function_handler = "dynamodb.lambda_handler"
s3_function_handler = "s3.lambda_handler"
runtime = "python3.12"
timeout = 60
apigateway_statement_id = "AllowAPIGatewayInvoke"
eventbridge_statement_id = "AllowEventBridgeInvok"
invoke_action = "lambda:InvokeFunction"
apigateway_principle = "apigateway.amazonaws.com"
eventbridge_principle = "eventbridge.amazonaws.com"
sqs_queue_name = "username-sqs-queue"
deadletter_queue_name = "username-deadletterqueue"
delay_seconds = 90
max_message_size = 2048
message_retention_seconds = 86400
receive_wait_time_seconds = 10
max_receive_count = 4
event_bus_name = "user-data-forwarder"
event_bus_description = "Event bus for routing events based on dynamodb table writes"
event_bus_rule_name =  "dynamodb-write-events"
event_bus_rule_description = "Capture all DynamoDB write events"
eventbridge_source = "aws.dynamodb"
detail_type = "DynamoDB Write Operation Successful"
lambda_dynamodb_role_name = "lambda-dynamodb-iam-role"
lambda_s3_role_name = "lambda-s3-iam-role"
logging_policy_name = "logging-policy"
dynamodb_policy_name = "dynamodb-policy"
dynamodb_streams_policy_name = "dynamodb-streams-policy"
s3_policy_name = "lambda-function-s3-policy"
cloudwatch_log_group_arn = "arn:aws:logs:*:*:*"
bucket_name = "user-data"
eventbridge_pipe_name = "dynamodb-to-eventbus-pipe"
eventbridge_policy_name = "eventbridge-put-events-policy"